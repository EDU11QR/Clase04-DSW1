@model WebApplication2026.Models.ClassCotizar

@{
    ViewData["Title"] = "Editar Cotización";
    Layout = "~/Views/Shared/_LayoutMaster.cshtml";
}

<h2 class="text-center mb-4">✏️ Editar Cotización</h2>

<div class="row justify-content-center">
    <div class="col-md-6">

        <!-- Mensaje de éxito/error -->
        @if (TempData["mensaje"] != null)
        {
            <div class="alert alert-info text-center">
                @TempData["mensaje"]
            </div>
        }

        <form asp-action="Edit" asp-controller="Compra" method="post">

            <!-- ID oculto -->
            <input type="hidden" asp-for="idcoti" />

            <div class="mb-3">
                <label asp-for="Cliente" class="form-label"></label>
                <input asp-for="Cliente" class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="Conce" class="form-label"></label>
                <input asp-for="Conce" class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="Cantidad" class="form-label"></label>
                <input asp-for="Cantidad" class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="Tvehi" class="form-label"></label>
                <select asp-for="Tvehi" class="form-select">
                    <option value="">-- Seleccione vehículo --</option>
                    <option value="camaro">Camaro</option>
                    <option value="camioneta">Camioneta</option>
                    <option value="comercial">Comercial</option>
                    <option value="cybertruck">Cybertruck</option>
                    <option value="pickup">Pickup</option>
                    <option value="sedan">Sedan</option>
                </select>
            </div>

            <!-- Solo lectura porque se calcula -->
            <div class="mb-3">
                <label asp-for="Precio" class="form-label"></label>
                <input asp-for="Precio" class="form-control" readonly />
            </div>

            <div class="mb-3">
                <label asp-for="Total" class="form-label"></label>
                <input asp-for="Total" class="form-control" readonly />
            </div>

            <div class="text-center mt-4">
                <button type="submit" class="btn btn-success me-2">
                   Guardar Cambios
                </button>

                <a asp-action="listadoCotizaciones" asp-controller="Compra" class="btn btn-secondary">
                   Cancelar
                </a>
            </div>

        </form>

    </div>
</div>