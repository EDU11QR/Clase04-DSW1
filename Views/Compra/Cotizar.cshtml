@model WebApplication2026.Models.ClassCotizar
@{
    ViewBag.Title = "sitio oficial de ventas de vehiculos";
    Layout = "~/Views/Shared/_LayoutMaster.cshtml";
}
<h1 style="text-align:center">
    COTIZA YA !!!!!!!!!!
</h1>
<br />
<div class="row justify-content-center">
    <div class="cod-md-4">
        <form asp-controller="Compra" 
              asp-action="CalculoCotizar">
              <br />
      
              <label>Cliente</label>
              <input asp-for="Cliente" class="form-control"
              style="text-align:center"/>
              <br />

            <label>Concesionario</label>
            <input asp-for="Conce" class="form-control"
                   style="text-align:center" />
            <br />  

            <label>Cantidad de vehiculo</label>
            <input asp-for="Cantidad" class="form-control"
                   style="text-align:center" />
            <br />
            <label>elige el vehiculo</label>
            <select asp-for="Tvehi">
                <option value="sel">seleccione vehiculo

                </option>
                <option value="camaro">camaro</option>
                <option value="camioneta">camioneta</option>
                <option value="comercial">comercial</option>
                <option value="cybertruck">cybertruck</option>
                <option value="pickup">pickup</option>
                <option value="sedan">sedan</option>
            </select>
            <br />
            <input type="submit" value="Cotizar" class="btn btn-warning" />

        </form>
    </div>
</div>